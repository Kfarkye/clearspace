    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^2.8.0",
    "@octokit/rest": "^22.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "ws": "^8.18.0",
    "yt-search": "^2.13.1",
    "zod": "^4.4.3"
