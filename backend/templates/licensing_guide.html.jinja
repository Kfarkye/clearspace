<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ data.title }} - Official Licensure Guide</title>
    <!-- Use Tailwind CSS for beautiful, deterministic branding -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3, h4, h5, h6 { font-family: 'Outfit', sans-serif; }
        .glass-panel { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        .bg-grid-pattern { background-image: radial-gradient(rgba(0, 0, 0, 0.05) 1px, transparent 1px); background-size: 24px 24px; }
        
        /* Print optimization for the Save as PDF utility */
        @media print {
            .no-print { display: none !important; }
            body { background: white !important; }
            .shadow-sm, .shadow-md { box-shadow: none !important; }
            .border { border-color: #e4e4e7 !important; }
        }
    </style>
</head>
<body class="bg-[#FAFAFA] text-zinc-800 antialiased min-h-screen pb-12 selection:bg-zinc-900 selection:text-white">
    <!-- Header -->
    <header class="relative bg-white border-b border-zinc-200/80 overflow-hidden">
        <div class="absolute inset-0 bg-grid-pattern opacity-50"></div>
        <div class="relative max-w-4xl mx-auto px-6 py-16 lg:py-20">
            <div class="flex flex-col md:flex-row md:items-start justify-between gap-6">
                <div>
                    <div class="inline-flex items-center space-x-2 bg-zinc-100 border border-zinc-200/80 rounded-full px-3 py-1 text-zinc-600 mb-6 text-[11px] font-bold tracking-widest uppercase">
                        <span>{{ data.state }}</span>
                        <span class="opacity-40">•</span>
                        <span>{{ data.profession }}</span>
                    </div>
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-5 leading-tight text-zinc-900">{{ data.title }}</h1>
                    <p class="text-zinc-500 text-lg md:text-xl max-w-2xl leading-relaxed font-normal">
                        {{ data.overview }}
                    </p>
                </div>
                
                <!-- Commercial Utility: Print/Save Action -->
                <div class="no-print shrink-0">
                    <button onclick="window.print()" class="group inline-flex items-center justify-center px-5 py-2.5 text-sm font-semibold text-zinc-700 bg-white border border-zinc-200/80 rounded-lg shadow-sm hover:bg-zinc-50 hover:border-zinc-300 transition-all focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2">
                        <svg class="w-4 h-4 mr-2 text-zinc-400 group-hover:text-zinc-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        Save as PDF
                    </button>
                </div>
            </div>

            <!-- Commercial Metric: Quick Facts Grid (ROI & Investment) -->
            {% if data.stats %}
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-12 pt-10 border-t border-zinc-100">
                {% for stat in data.stats %}
                <div class="bg-zinc-50/50 rounded-xl p-4 border border-zinc-100">
                    <p class="text-[11px] font-semibold text-zinc-500 uppercase tracking-wider mb-1">{{ stat.label }}</p>
                    <p class="text-xl font-bold text-zinc-900">{{ stat.value }}</p>
                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-10 relative z-10">
        
        <!-- Verification Banner (Enhanced Trust Signal) -->
        <div class="bg-emerald-50/50 rounded-xl p-4 mb-12 flex items-center shadow-sm border border-emerald-100">
            <div class="relative flex h-3 w-3 mr-3 shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
            </div>
            <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-2 text-sm">
                <h3 class="text-emerald-900 font-semibold tracking-tight">Verified Official Data</h3>
                <span class="hidden sm:inline text-emerald-300">•</span>
                <p class="text-emerald-700 font-normal">Information confirmed accurate with state boards as of {{ data.last_verified }}.</p>
            </div>
        </div>

        <!-- Paths -->
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-semibold text-zinc-900 tracking-tight">Licensure Paths</h2>
        </div>
        
        <div class="space-y-8">
            {% for path in data.paths %}
            <section class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 border border-zinc-200/80 overflow-hidden group">
                <div class="bg-zinc-50/80 px-8 py-6 border-b border-zinc-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                    <div>
                        <h3 class="text-xl font-semibold text-zinc-900">{{ path.name }}</h3>
                        <p class="text-zinc-500 text-sm mt-1.5 font-normal">{{ path.description }}</p>
                    </div>
                    {% if path.badge %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-100 shrink-0">
                        {{ path.badge }} <!-- e.g., "Most Popular", "Fastest Route" -->
                    </span>
                    {% endif %}
                </div>
                
                <div class="p-8">
                    <div class="space-y-10">
                        {% for step in path.steps %}
                        <div class="relative pl-12 group/step hover:bg-zinc-50/50 -mx-4 p-4 rounded-xl transition-colors">
                            <!-- Timeline node -->
                            <div class="absolute left-4 top-5 w-8 h-8 bg-zinc-900 text-white border-4 border-white rounded-full flex items-center justify-center text-xs font-bold shadow-sm z-10 group-hover/step:scale-110 transition-transform">
                                {{ loop.index }}
                            </div>
                            <!-- Timeline line -->
                            {% if not loop.last %}
                            <div class="absolute left-[31px] top-12 bottom-[-2.5rem] w-[2px] bg-zinc-100"></div>
                            {% endif %}
                            
                            <h4 class="text-lg font-semibold text-zinc-900 mb-2">{{ step.title }}</h4>
                            <p class="text-zinc-600 leading-relaxed text-sm">{{ step.description }}</p>
                            
                            {% if step.estimated_cost or step.estimated_time %}
                            <div class="mt-4 flex flex-wrap gap-2">
                                {% if step.estimated_time %}
                                <span class="inline-flex items-center px-3 py-1.5 rounded-md text-[11px] font-semibold bg-white text-zinc-600 border border-zinc-200 shadow-sm">
                                    <svg class="w-3.5 h-3.5 mr-1.5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    {{ step.estimated_time }}
                                </span>
                                {% endif %}
                                {% if step.estimated_cost %}
                                <span class="inline-flex items-center px-3 py-1.5 rounded-md text-[11px] font-semibold bg-white text-zinc-600 border border-zinc-200 shadow-sm">
                                    <svg class="w-3.5 h-3.5 mr-1.5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    {{ step.estimated_cost }}
                                </span>
                                {% endif %}
                            </div>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
            {% endfor %}
        </div>

        <!-- Official Sources -->
        <div class="flex items-center justify-between mt-16 mb-6">
            <h2 class="text-2xl font-semibold text-zinc-900 tracking-tight">Official Sources</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-16">
            {% for source in data.official_sources %}
            <a href="{{ source.url }}" target="_blank" rel="noopener noreferrer" class="group block bg-white border border-zinc-200/80 rounded-xl p-5 hover:shadow-md hover:border-zinc-300 transition-all duration-200">
                <div class="flex justify-between items-start">
                    <div class="pr-4">
                        <span class="inline-block px-2 py-0.5 bg-zinc-100 text-zinc-600 rounded text-[10px] font-bold uppercase tracking-wider mb-2.5">{{ source.type }}</span>
                        <h4 class="text-zinc-900 font-semibold text-sm group-hover:text-blue-600 transition-colors line-clamp-2 leading-snug">{{ source.name }}</h4>
                    </div>
                    <div class="text-zinc-300 group-hover:text-blue-500 transition-colors shrink-0 mt-1 bg-zinc-50 group-hover:bg-blue-50 rounded-full p-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>

        <!-- Commercial Lead Generation CTA -->
        <div class="no-print relative rounded-2xl bg-zinc-900 overflow-hidden shadow-xl border border-zinc-800">
            <!-- Decorative background elements -->
            <div class="absolute top-0 right-0 -mt-16 -mr-16 w-64 h-64 bg-zinc-800 rounded-full blur-3xl opacity-50"></div>
            <div class="absolute bottom-0 left-0 -mb-16 -ml-16 w-64 h-64 bg-blue-900/30 rounded-full blur-3xl opacity-50"></div>
            
            <div class="relative px-8 py-12 md:p-12 md:flex md:items-center md:justify-between text-center md:text-left">
                <div class="mb-8 md:mb-0 md:pr-8">
                    <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight mb-3">
                        {{ data.cta.title | default("Need help navigating this process?") }}
                    </h2>
                    <p class="text-zinc-400 text-lg max-w-xl">
                        {{ data.cta.description | default("Connect with our licensing experts to streamline your application and avoid costly delays.") }}
                    </p>
                </div>
                <div class="shrink-0">
                    <a href="{{ data.cta.url | default('#') }}" class="inline-flex items-center justify-center px-6 py-3.5 border border-transparent text-base font-semibold rounded-lg text-zinc-900 bg-white hover:bg-zinc-100 shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-zinc-900 focus:ring-white">
                        {{ data.cta.button_text | default("Get Expert Assistance") }}
                    </a>
                </div>
            </div>
        </div>

    </main>

    <footer class="mt-8 py-8 border-t border-zinc-200 bg-[#FAFAFA] text-zinc-500 text-center text-sm font-medium">
        <p>Generated deterministically by Clearspace Compiler</p>
    </footer>
</body>
</html>
