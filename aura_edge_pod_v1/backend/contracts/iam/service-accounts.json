{
  "version": "1.0",
  "domain": "aura-production-2026",
  "serviceAccounts": {
    "aura-edge-pod-sa": { "purpose": "Public HTTP API, TrustGate creation", "permissions": ["spanner.read", "spanner.write", "cloudtasks.enqueue"] },
    "aura-worker-sa": { "purpose": "Executes governed jobs", "permissions": ["spanner.read", "spanner.write", "artifactregistry.write"] },
    "aura-task-invoker-sa": { "purpose": "Invokes Cloud Run workers via OIDC", "permissions": ["run.invoke"] },
    "aura-research-worker-sa": { "purpose": "Deep research async worker", "permissions": ["spanner.read", "spanner.write"] },
    "aura-media-resolver-sa": { "purpose": "Media resolver worker", "permissions": ["spanner.read", "spanner.write"] },
    "aura-sports-ingest-sa": { "purpose": "Sports data ingest worker", "permissions": ["spanner.read", "spanner.write"] },
    "aura-oauth-broker-sa": { "purpose": "Retrieves user OAuth tokens", "permissions": ["secretmanager.versions.access", "cloudkms.cryptoKeyVersions.useToDecrypt"] }
  }
}
